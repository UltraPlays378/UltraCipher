{
  "$schema": "node_modules/wrangler/config-schema.json",

  // Worker project name
  "name": "ultracipher",

  // Entry file — your Worker code
  "main": "UltraCipher.js",

  // Cloudflare compatibility date
  "compatibility_date": "2025-02-04",

  "observability": {
    "enabled": true
  },

  // KV namespace binding
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "4463b4470c604e0593eb3a6cf6213399"
    }
  ],

  // Worker rate limiting binding
  "ratelimits": [
    {
      "name": "ULTRACIPHER_RATE_LIMIT",
      "namespace_id": "378",
      "simple": {
        "limit": 60,
        "period": 60
      }
    }
  ]
}
